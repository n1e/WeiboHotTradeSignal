{
  "weibo": {
    "cookie_sub": "your_weibo_cookie_sub_value_here",
    "api_url": "https://s.weibo.com/top/summary?cate=realtimehot"
  },
  "openrouter": {
    "api_key": "your_openrouter_api_key_here",
    "api_url": "https://openrouter.ai/api/v1/chat/completions",
    "model": "gpt-4o-mini"
  },
  "data": {
    "storage_dir": "./data",
    "history_days": 7,
    "use_duckdb": true,
    "db_path": "./data/weibo_hot.duckdb"
  },
  "report": {
    "output_dir": "./reports",
    "template_file": "./templates/report_template.html"
  },
  "schedule": {
    "enabled": true,
    "interval_minutes": 2,
    "active_hours": "09:00-21:00",
    "timezone": "Asia/Shanghai"
  },
  "push": {
    "enabled": false,
    "feishu": {
      "enabled": false,
      "app_id": "your_feishu_app_id",
      "app_secret": "your_feishu_app_secret",
      "chat_id": "your_feishu_chat_id"
    }
  },
  "logging": {
    "level": "INFO",
    "file": "./logs/app.log",
    "max_size_mb": 10,
    "backup_count": 5
  },
  "summary": {
    "max_snapshots_for_daily": 5,
    "max_topics_for_daily": 20,
    "max_topics_for_weekly": 15,
    "daily_cron": "0 22 * * *",
    "weekly_cron": "0 23 * * 0"
  }
}
