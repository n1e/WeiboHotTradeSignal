{
  "weibo": {
    "cookie_sub": "your_weibo_cookie_sub_value_here",
    "api_url": "https://s.weibo.com/top/summary?cate=realtimehot"
  },
  "openrouter": {
    "api_key": "your_openrouter_api_key_here",
    "api_url": "https://openrouter.ai/api/v1/chat/completions",
    "model": "gpt-4o-mini"
  },
  "data": {
    "storage_dir": "./data",
    "history_days": 7,
    "use_duckdb": true,
    "db_path": "./data/weibo_hot.duckdb"
  },
  "report": {
    "output_dir": "./reports",
    "template_file": "./templates/report_template.html"
  },
  "schedule": {
    "enabled": true,
    "interval_minutes": 10,
    "active_hours": "09:00-21:00",
    "timezone": "Asia/Shanghai"
  },
  "summary": {
    "daily": {
      "enabled": true,
      "time": "22:00"
    },
    "weekly": {
      "enabled": true,
      "time": "23:00",
      "day": 6
    }
  },
  "investment_mining": {
    "daily": {
      "enabled": true,
      "time": "21:30"
    }
  },
  "push": {
    "enabled": true,
    "feishu": {
      "enabled": true,
      "app_id": "your_feishu_app_id",
      "app_secret": "your_feishu_app_secret",
      "chat_id": "your_feishu_chat_id",
      "webhook_url": ""
    }
  },
  "logging": {
    "level": "INFO",
    "file": "./logs/app.log",
    "max_size_mb": 10,
    "backup_count": 5
  }
}